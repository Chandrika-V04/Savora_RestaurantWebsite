@page
@model Restuarant.Pages.VegModel
@{
}
<link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />

<section class="menu-banner">
    <div class="banner-overlay">
        <h1>VEGETARIAN MENU</h1>
        <div class="gold-line"></div>
        <p>Pure Flavours. Royal Elegance.</p>
    </div>
</section>

<!-- CATEGORY BUTTONS -->
<section class="menu-categories">
    <div class="category-container">
        <a href="#starters" class="category-btn">STARTERS</a>
        <a href="#maincourse" class="category-btn">MAIN COURSE</a>
        <a href="#soups" class="category-btn">SOUPS</a>
    </div>
</section>

<!-- ================= STARTERS ================= -->
<section id="starters" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Light & Flavorful</span>
        <h2>VEG STARTERS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/panner.jpg" alt="Paneer Tikka">
            <h3>Paneer Tikka Medallions</h3>
            <p>Chargrilled cottage cheese infused with royal spices and smoked to perfection.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/mushroom.jpg" alt="Mushroom Galouti">
            <h3>Truffle Mushroom Galouti</h3>
            <p>Soft melt-in-mouth patties enriched with aromatic truffle essence.</p>
        </div>

        <div class="menu-card">
            <img src="~/Images/Menu/veg1.jpg" alt="Veg Kebab">
            <h3>Stuffed Paneer Volcano</h3>
            <p>Crispy paneer pockets stuffed with molten cheese and herbs, served with a spicy lava dip.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg2.jpg" alt="Cheese Balls">
            <h3>Smoked Corn & Cheese Cigars</h3>
            <p>Golden crispy rolls filled with smoky corn and creamy cheese, served with mint aioli.</p>
        </div>

    </div>
</section>

<!-- ================= MAIN COURSE ================= -->
<section id="maincourse" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Rich & Hearty</span>
        <h2>MAIN COURSE</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/dal makhani.jpg" alt="Dal Makhani">
            <h3>Smoked Dal Makhani</h3>
            <p>Slow-cooked black lentils simmered overnight for deep, rich flavor.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg biryani.jpg" alt="Veg Biryani">
            <h3>Royal Vegetable Biryani</h3>
            <p>Fragrant basmati rice layered with seasonal vegetables and saffron.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg8.jpeg" alt="Veg Biryani">
            <h3>Malai Kofta</h3>
            <p>Soft dumplings stuffed with dry fruits, served in a rich, creamy cashew gravy.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg7.jpeg" alt="Paneer Lababdar">
            <h3>Paneer Lababdar Indulgence</h3>
            <p>Paneer simmered in a rich tomato-butter gravy with subtle smoky and cramy notes.</p>
        </div>
    </div>
</section>

<!-- ================= SOUPS ================= -->
<section id="soups" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Warm & Comforting</span>
        <h2>SOUPS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/veg3.jpg" alt="Tomato Soup">
            <h3>Truffle Forest Mushroom Velouté</h3>
            <p>A silky blend of wild mushrooms infused with truffle essence, finished with cream for a deep, earthy richness.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg4.jpg" alt="Sweet Corn Soup">
            <h3>Saffron Infused Carrot Essence</h3>
            <p>A vibrant carrot soup delicately infused with saffron, offering a smooth, mildly sweet.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg5.jpg" alt="Manchow Soup">
            <h3>Emerald Broccoli Almond Soup</h3>
            <p>A smooth and nourishing blend of broccoli and toasted almonds, enriched with subtle creaminess.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/veg6.jpg" alt="Mushroom Soup">
            <h3>Coconut Lemongrass Broth</h3>
            <p>A light coconut broth infused with lemongrass and aromatic herbs, offering a fresh and exotic flavor.</p>
        </div>
    </div>
</section>
<a asp-page="/Menumain" class="floating-back-btn">Back to Menu</a>
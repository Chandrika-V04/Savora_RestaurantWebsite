@page
@model Restaurant.Pages.Admin.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin Login</title>
    <link rel="stylesheet" href="/css/Admin.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter&family=Playfair+Display&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="left">
            <div class="brand-wrapper">
                <h1 class="brand">Savora</h1>
                <div class="tagline">Rooted in tradition. Refined for today.</div></div>
     </div>
        <div class="right">
            <div class="login-box">
                <h2>Welcome Back</h2>
                <p>Please enter your administrative credentials.</p>
                <form method="post">
                    <div class="input-group">
                        <i class="fa-solid fa-user"></i>
                        <input type="text" asp-for="Username" placeholder="Username" />
                    </div>
                    <div class="input-group">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" asp-for="Password" placeholder="Password" required /></div>
                    <button type="submit">Sign In</button>
                </form>
                <div class="footer-text">
                    &copy; 2026 Savora Restaurant Group. Protected Access.</div>
            </div>
        </div>
    </div>
</body>
</html>
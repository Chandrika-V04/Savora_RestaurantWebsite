@page
@model Restuarant.Pages.AlcoholModel
@{
    ViewData["Title"] = "Menu";
    Layout = "_Layout";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/Menu.css">
<section class="veg-banner">
    <img src="/images/alcohol.jpg" class="veg-bg-img" alt="Beverage Banner" />
    <div class="veg-overlay">
        <h1 style="color: #E6C88C; font-family: 'Playfair Display';">The Liquid Gold</h1>
        <p style="letter-spacing: 3px; text-transform: uppercase;">Botanical Infusions • Velvet Shakes • Artisan Alchemy</p>
    </div>
</section>
<nav class="menu-nav-sticky" style="background-color: #061b36;">
    <div class="nav-row">
        <a href="#cocktails">Cocktails </a>
        <a href="#wine">Wine</a>
        <a href="#whisky">Whisky</a>
        <a href="#beer">Beer </a>
        <a href="#vodka">Vodka </a>
        <a href="#rum">Rum  </a>
        <div class="filter-divider"></div>
        <button class="filter-btn active" onclick="filterMenu('all')">All</button>
        <button class="filter-btn" onclick="filterMenu('smokey')">Smokey <span class="btn-desc">Oaked & Bold</span></button>
        <button class="filter-btn" onclick="filterMenu('crisp')">Crisp <span class="btn-desc">Fresh & Zesty</span></button>
        <button class="filter-btn" onclick="filterMenu('velvet')">Velvet <span class="btn-desc">Creamy & Silk</span></button>
    </div>
</nav>
<section id="cocktails" class="menu-category-block" style="background-color: #061b36;">

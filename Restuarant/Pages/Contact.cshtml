@page
@model Restuarant.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
    Layout = "_Layout";
}
<link rel="stylesheet" href="~/css/Contact.css" asp-append-version="true" />

<section class="contact-hero">
    <div class="contact-hero-overlay">
        <h1>CONTACT US</h1>
            <p>Reach out to us anytime, we’re here for you.</p>
    </div>
</section>
<section class="get-in-touch">
    <div class="get-in-touch-header">
        <span class="section-tag">Connect With Us</span>
        <h2>Get In Touch</h2>
        <p>Drop by our branches or send us a message for reservations, events, and personalized dining experiences.</p>
    </div>
    <div class="contact-cards">
        <div class="contact-card">
           <span class="icon">📍</span>
           <h4>Whitefield Branch</h4>
           <p>Whitefield Main Road<br> Bangalore – 560066</p>
           <span class="contact-small">📞 +91 98765 43210</span>
        </div>
        <div class="contact-card">
            <span class="icon">📍</span>
            <h4>Hennur Branch</h4>
             <p>Hennur Main Road<br>Bangalore – 560043</p>
                <span class="contact-small">📞 +91 98765 43210</span>
        </div>
        <div class="contact-card">
            <span class="icon">✉️</span>
            <h4>Email Us</h4>
            <p>homeofflavours@gmail.com</p>
            <span class="contact-small">We respond within 24 hours</span>
        </div>
    </div>
</section>
    <section class="reserve-hero">
        <div class="reserve-overlay"></div>

        <div class="reserve-content">
            <span class="small-tag">BOOK NOW</span>
            <h1>Reserve A Table Now</h1>

            <div class="btn-group">
                <a href="#" class="btn primary">MAKE A RESERVATION</a>
            </div>
        </div>
</section>
<section class="contact-form-section">
    <div class="side-image left-img"></div>
        <div class="contact-form-container">
            <h2>Send Us a Message</h2>
            <p class="subtitle">We’d love to hear from you</p>
            <form method="post">
                <div class="form-group">
                    <label>Name</label>
                    <input type="text" asp-for="Name" required />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" asp-for="Email" required />
                </div>
                <div class="form-group">
                    <label>Subject</label>
                    <input type="text" asp-for="Subject" required />
                </div>
                <div class="form-group">
                    <label>Message</label>
                    <textarea asp-for="Message" required></textarea>
                </div>
            <button type="submit" class="btn-outline-gold">Contact Us</button>
            </form>
        </div>
    <div class="side-image right-img"></div>
</section>



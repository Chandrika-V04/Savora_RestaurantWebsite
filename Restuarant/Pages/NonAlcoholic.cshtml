                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="veg-card featured sold-out" data-category="botanical">
            <div class="card-img-box">
                <img src="/images/Berry Blush Cooler.jpg" alt="Passion Punch">

            </div>
            <div class="card-content">
                <h3>Berry Blush Cooler</h3>
                <p>Mixed berry flavors with a refreshing sweet-tart balance.</p>
                <div class="card-footer"><span class="price-text">₹215</span></div>
            </div>
        </div>
        <div class="veg-card" data-category="botanical">
            <div class="card-img-box">
                <img src="/images/Cucumber Mint Sparkler.jpg" alt="Passion Punch">
                <div class="signature-tag">★ Chilled</div>

            </div>
            <div class="card-content">
                <h3>Cucumber Mint Sparkler</h3>
                <p>Cool cucumber juice with mint and soda bubbles.</p>
                <div class="card-footer">
                    <span class="price-text">₹210</span>
                    <button class="wishlist-btn"
                            data-name="Cucumber Mint Sparkler"
                            data-price="210"
                            onclick="toggleVisitList(this)">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="veg-card" data-category="zest">
            <div class="card-img-box">
                <img src="/images/Sunset Mango Splash.jpg" alt="Passion Punch">

            </div>
            <div class="card-content">
                <h3>Sunset Mango Splash</h3>
                <p>Ripe mango flavor layered with citrus freshness.</p>
                <div class="card-footer">
                    <span class="price-text">₹265</span>
                    <button class="wishlist-btn"
                            data-name="Sunset Mango Splash"
                            data-price="265"
                            onclick="toggleVisitList(this)">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
        <div class="veg-card" data-category="zest">
            <div class="card-img-box">
                <img src="/images/Blue Ocean Cooler.jpg" alt="Passion Punch">
                <div class="signature-tag">★ Chef's Signature</div>
            </div>
            <div class="card-content">
                <h3>Blue Ocean Cooler</h3>
                <p>Tropical blue mocktail with citrus and icy chill.</p>
                <div class="card-footer">
                    <span class="price-text">₹315</span>
                    <button class="wishlist-btn"
                            data-name="Blue Ocean Cooler"
                            data-price="315"
                            onclick="toggleVisitList(this)">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>

    </div>
</section>
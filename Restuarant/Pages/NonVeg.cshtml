@page
@model Restuarant.Pages.NonvegModel
@{
}
<link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />

<section class="menu-banner">
    <div class="banner-overlay">
        <h1>NON-VEGETARIAN MENU</h1>
        <div class="gold-line"></div>
        <p>Bold Flavours. Royal Indulgence.</p>
    </div>
</section>

<!-- CATEGORY BUTTONS -->
<section class="menu-categories">
    <div class="category-container">
        <a href="#starters" class="category-btn">STARTERS</a>
        <a href="#maincourse" class="category-btn">MAIN COURSE</a>
        <a href="#soups" class="category-btn">SOUPS</a>
    </div>
</section>

<!-- ================= STARTERS ================= -->
<section id="starters" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Light & Flavorful</span>
        <h2>NON-VEG STARTERS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/non1.jpg" alt="Chicken Tikka">
            <h3>Classic Chicken Tikka</h3>
            <p>Juicy chicken marinated in spices and grilled to smoky perfection.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non2.jpg" alt="Seekh Kebab">
            <h3>Seekh Kebab Royale</h3>
            <p>Minced meat skewers infused with herbs and grilled over open flame.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non3.jpg" alt="Fish Fry">
            <h3>Coastal Fish Fry</h3>
            <p>Fresh fish marinated in coastal spices and crisp fried.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non4.jpg" alt="Tandoori Platter">
            <h3>Tandoori Supreme Platter</h3>
            <p>Chef’s curated selection of charcoal-roasted meats with signature marinades.</p>
        </div>
    </div>
</section>

<!-- ================= MAIN COURSE ================= -->
<section id="maincourse" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Rich & Hearty</span>
        <h2>MAIN COURSE</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/chicken.jpg" alt="Butter Chicken">
            <h3>Royal Ember Butter Chicken</h3>
            <p>Fire-roasted chicken simmered in velvety makhani sauce with a delicate smoky finish.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/lamb.jpg" alt="Lamb Rogan Josh">
            <h3>Mughal Reserve Lamb Rogan</h3>
            <p>Tender lamb slow-cooked in aromatic Kashmiri spices for a deep, royal flavor.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/prawns.jpg" alt="Prawn Masala">
            <h3>Coastal Flame Prawn Masala</h3>
            <p>Succulent prawns tossed in bold coastal spices with a rich, flavorful glaze.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/platter.jpg" alt="Tandoori Platter">
            <h3>Tandoori Supreme Platter</h3>
            <p>Chef’s curated selection of charcoal-roasted meats with signature marinades.</p>
        </div>
    </div>
</section>

<!-- ================= SOUPS ================= -->
<section id="soups" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Warm & Comforting</span>
        <h2>SOUPS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/non5.jpg" alt="Chicken Soup">
            <h3>Classic Chicken Clear Soup</h3>
            <p>Light and nourishing soup with tender chicken and herbs.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non6.jpg" alt="Mutton Soup">
            <h3>Spiced Mutton Soup</h3>
            <p>Rich broth infused with spices and slow-cooked mutton.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non8.jpg" alt="Hot and Sour Soup">
            <h3>Coastal Prawn Soup</h3>
            <p>A light yet flavorful soup with prawns, coconut milk, and coastal spices.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/non7.jpg" alt="Hot and Sour Soup">
            <h3>Mutton Bone Broth Elixir</h3>
            <p>Slow-simmered mutton bones creating a deeply nourishing, flavorful, and aromatic broth.</p>
        </div>
    </div>
</section>
<a asp-page="/Menumain" class="floating-back-btn">Back to Menu</a>


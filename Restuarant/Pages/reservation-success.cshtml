@page
@{

    Layout = null;
}

<link rel="stylesheet" href="~/css/reservation-success.css" />

<section class="success-section">
    <div class="success-card">

        <h1>Thank You!</h1>

        <p class="confirmation">
            Your reservation has been successfully submitted.
        </p>

        <p class="message">
            We truly appreciate your interest in dining with us.
            Our team will get in touch with you shortly to confirm the details.
        </p>

        <div class="action-buttons">
            <a asp-page="/Index" class="btn primary">Home</a>
            <a asp-page="/Contact" class="btn secondary">Contact</a>
        </div>

        <p class="info-text">
            For further information, please contact us.
            We are always happy to assist you.
        </p>

    </div>
</section>


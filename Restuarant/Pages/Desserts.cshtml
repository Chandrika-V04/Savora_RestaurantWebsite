@page
@model Restuarant.Pages.DessertsModel
@{
}
<link rel="stylesheet" href="~/css/Menu.css" asp-append-version="true" />

<section class="menu-banner">
    <div class="banner-overlay">
        <h1>DESSERTS & DRINKS</h1>
        <div class="gold-line"></div>
        <p>Sweet Indulgence & Crafted Beverages</p>
    </div>
</section>
<section class="menu-categories">
    <div class="category-container">
        <a href="#desserts" class="category-btn">DESSERTS</a>
        <a href="#alcoholic" class="category-btn">ALCOHOLIC</a>
        <a href="#nonalcoholic" class="category-btn">NON-ALCOHOLIC</a>
    </div>
</section>

<section id="desserts" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Sweet Indulgence</span>
        <h2>DESSERT CREATIONS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/d1.jpg" alt="Rasmalai">
            <h3>Saffron Pistachio Cheesecake</h3>
            <p>Creamy cheesecake infused with saffron, finished with pistachio crumble.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/d2.jpg" alt="Gulab Jamun">
            <h3>Rosé Cream Delight</h3>
            <p>Silky rose-infused panna cotta topped with pistachio crumble and delicate rose petals.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/d3.jpg" alt="Kulfi">
            <h3>Cardamom Pistachio Macarons</h3>
            <p>Delicate macarons infused with cardamom, layered with pistachio cream and a refined nutty finish.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/d4.jpg" alt="Gulab Jamun">
            <h3>Saffron Phirni Tart</h3>
            <p>Creamy saffron phirni set in a crisp almond tart, finished with pistachio and rose petals.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/rasmalai.jpg" alt="Rasmalai">
            <h3>Saffron Silk Rasmalai</h3>
            <p>Delicate cottage cheese dumplings soaked in saffron-infused sweet cream, finished with pistachio crumble.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/d5.jpg" alt="Gulab Jamun">
            <h3>Jalebi Rabri Mille-Feuille</h3>
            <p>Crisp layered pastry filled with rich rabri cream, finished with delicate jalebi garnish.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/kulfi.jpg" alt="Kulfi">
            <h3>Rose Petal Kulfi Delight</h3>
            <p>Traditional slow-churned kulfi infused with rose essence and subtle floral sweetness.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/Pistachio.jpg" alt="Pistachio Eclair">
            <h3>Pistachio Cardamom Éclair</h3>
            <p>A modern fusion dessert filled with pistachio cream and infused with aromatic cardamom.</p>
        </div>
    </div>
</section>

<section id="alcoholic" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Bold & Crafted</span>
        <h2>ALCOHOLIC BEVERAGES</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/masala.jpeg" alt="Royal Masala Martini">
            <h3>Royal Masala Martini</h3>
            <p>A refined blend of subtle Indian spices and premium spirits, crafted with modern elegance.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/drink2.jpg" alt="Mango Basil Elixir">
            <h3>Spiced Whiskey Sour</h3>
            <p>A bold mix of aged whiskey, citrus, and subtle Indian spice notes.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/drink1.jpg" alt="Saffron Citrus Spritz">
            <h3>Rose Infused Wine Spritz</h3>
            <p>Light sparkling wine blended with rose essence for a floral, refreshing sip.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/drink3.jpg" alt="Saffron Citrus Spritz">
            <h3>Golden Honey Rum Punch desc</h3>
            <p>A smooth blend of golden rum, honey sweetness, and citrus, finished with a refreshing tropical twist.</p>
        </div>

    </div>
</section>

<section id="nonalcoholic" class="menu-grid-section">
    <div class="menu-heading">
        <span class="category-subtitle">Fresh & Refreshing</span>
        <h2>NON-ALCOHOLIC DRINKS</h2>
        <div class="gold-line-center"></div>
    </div>
    <div class="menu-grid">
        <div class="menu-card">
            <img src="~/Images/Menu/mango.jpeg" alt="Mango Basil Elixir">
            <h3>Mango Basil Elixir</h3>
            <p>Fresh ripe mango blended with aromatic basil and a hint of citrus for a vibrant finish.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/saffron.jpeg" alt="Saffron Citrus Spritz">
            <h3>Saffron Citrus Spritz</h3>
            <p>A sparkling infusion of saffron and bright citrus notes, delicately balanced and refreshing.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/tamarind.jpeg" alt="Tamarind Spark Tonic">
            <h3>Tamarind Spark Tonic</h3>
            <p>Sweet and tangy tamarind infusion with a sparkling twist and a smooth herbal finish.</p>
        </div>
        <div class="menu-card">
            <img src="~/Images/Menu/drink.jpg" alt="Masala Drink">
            <h3>Rose Lychee Cooler</h3>
            <p>A refreshing blend of lychee and rose essence with a light floral finish.</p>
        </div>
    </div>
</section>
<a asp-page="/Menumain" class="floating-back-btn">Back to Menu</a>
